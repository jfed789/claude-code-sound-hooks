# demo.tape — run with: vhs demo.tape
# Generates demo.gif for the claude-code-sound-hooks README

Output demo.gif

Set Shell "bash"
Set FontSize 14
Set Width 720
Set Height 380
Set Theme "Dracula"
Set FontFamily "JetBrains Mono"
Set Padding 20
Set Framerate 24
Set PlaybackSpeed 1

Hide
Type "bash demo-hook.sh"
Show

Sleep 300ms
Enter
Sleep 6s

Sleep 1s

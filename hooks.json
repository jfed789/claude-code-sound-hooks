{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "Notification": [
    {
      "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash|Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "SubagentStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.claude/sounds/masterchief/play.sh",
          "timeout": 10
        }
      ]
    }
  ]
}
